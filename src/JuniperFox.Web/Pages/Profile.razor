@page "/profile"
@using System.Net
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Profile — JuniperFox</PageTitle>

@if (_checking)
{
    <p class="jf-muted">Loading…</p>
}
else
{
    <h1>Profile</h1>
    <p class="jf-muted">Your account and sign out.</p>

    <div class="jf-stack" style="margin-top: 1.5rem;">
        <NavLink href="/logout" class="jf-btn jf-btn-ghost" style="width: 100%;">Sign out</NavLink>
    </div>
}

@code {
    private bool _checking = true;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("Api");
        var response = await client.GetAsync("api/product-lists");
        if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _checking = false;
    }
}
