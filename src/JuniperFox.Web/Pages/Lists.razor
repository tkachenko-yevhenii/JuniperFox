@page "/lists"
@using System.Net
@implements IDisposable
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject LastOpenedListStorage LastOpenedList

<PageTitle>Lists — JuniperFox</PageTitle>

@if (_toastVisible)
{
    <div class="jf-toast-host" role="status" aria-live="polite">
        <div class="jf-toast">
            <span class="jf-toast-msg">@_toastMessage</span>
            <div class="jf-toast-actions">
                <button type="button" class="jf-btn jf-btn-ghost" disabled="@IsActionBusy" @onclick="UndoDeleteListAsync">Undo</button>
            </div>
        </div>
    </div>
}

<h1>Lists</h1>
<p class="jf-muted" style="margin-bottom: 1.25rem;">Pick a list or create a new one.</p>

@if (!string.IsNullOrEmpty(_error))
{
    <p class="jf-error">@_error</p>
}

@if (_lists is null)
{
    <p class="jf-muted">Loading…</p>
}
else if (_lists.Count == 0)
{
    <p class="jf-muted">No lists yet — create your first one below.</p>
}
else
{
    var ownLists = _lists.Where(l => l.IsOwnedByCurrentUser).ToList();
    var sharedLists = _lists.Where(l => !l.IsOwnedByCurrentUser).ToList();

    <div class="jf-stack-tight" style="margin-bottom: 1.5rem;">
        @if (ownLists.Count > 0)
        {
            <h2>My lists</h2>
            @foreach (var l in ownLists)
            {
                <div @key="l.Id" class="jf-list-row jf-lists-row">
                    <NavLink href="@($"/lists/{l.Id}")" class="jf-lists-row-link">
                        <span style="font-weight: 500;">@l.Title</span>
                        <span class="jf-muted" style="font-size: 1.25rem;" aria-hidden="true">›</span>
                    </NavLink>
                    <button type="button"
                            class="jf-btn jf-btn-ghost"
                            title="Share list"
                            aria-label="Share list"
                            disabled="@(IsActionBusy || _shareBusy)"
                            @onclick="() => OpenSharePanel(l.Id)">
                        Share
                    </button>
                    <button type="button"
                            class="jf-item-delete"
                            title="Delete list"
                            aria-label="Delete list"
                            disabled="@(_busyDeletingId == l.Id || IsActionBusy || _shareBusy)"
                            @onclick="() => DeleteListAsync(l.Id)">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                        </svg>
                    </button>
                </div>

                @if (_shareListId == l.Id)
                {
                    <div class="jf-card jf-stack-tight" style="margin-top: -0.5rem; margin-bottom: 0.35rem;">
                        <div class="jf-field">
                            <label>Find account to share with</label>
                            <input class="jf-input"
                                   value="@_shareQuery"
                                   placeholder="At least 3 characters"
                                   @oninput="OnShareQueryChanged"
                                   disabled="@_shareBusy" />
                        </div>
                        @if (_shareQuery.Trim().Length > 0 && _shareQuery.Trim().Length < 3)
                        {
                            <p class="jf-muted" style="margin: 0;">Type at least 3 symbols.</p>
                        }
                        @if (_shareSearchBusy)
                        {
                            <p class="jf-muted" style="margin: 0;">Searching…</p>
                        }
                        else if (_shareQuery.Trim().Length >= 3)
                        {
                            @if (_shareCandidates.Count == 0)
                            {
                                <p class="jf-muted" style="margin: 0;">No users found.</p>
                            }
                            else
                            {
                                <div class="jf-stack-tight">
                                    @foreach (var user in _shareCandidates)
                                    {
                                        var selected = _selectedShareUserId == user.Id;
                                        <button type="button"
                                                class="jf-btn @(selected ? "jf-btn-primary" : "jf-btn-ghost")"
                                                style="justify-content: flex-start;"
                                                @onclick="() => SelectShareCandidate(user.Id)">
                                            @user.UserName
                                        </button>
                                    }
                                </div>
                            }
                        }
                        @if (_shareMembers.Count > 0)
                        {
                            <div class="jf-stack-tight" style="margin-top: 0.5rem;">
                                <p class="jf-muted" style="margin: 0;">Already shared with</p>
                                @foreach (var member in _shareMembers)
                                {
                                    <div class="jf-list-row" style="margin-bottom: 0;">
                                        <span>@member.UserName</span>
                                        <button type="button"
                                                class="jf-btn jf-btn-ghost"
                                                disabled="@_shareBusy"
                                                @onclick="() => UnshareAsync(member.UserId)">
                                            Unshare
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        <div style="display: flex; gap: 0.75rem;">
                            <button type="button"
                                    class="jf-btn jf-btn-primary"
                                    disabled="@(_selectedShareUserId is null || _shareBusy)"
                                    @onclick="ShareSelectedAsync">
                                OK
                            </button>
                            <button type="button"
                                    class="jf-btn jf-btn-ghost"
                                    disabled="@_shareBusy"
                                    @onclick="CloseSharePanel">
                                Cancel
                            </button>
                        </div>
                    </div>
                }
            }
        }

        @if (sharedLists.Count > 0)
        {
            <h2 style="margin-top: 0.35rem;">Shared with me</h2>
            @foreach (var l in sharedLists)
            {
                <div @key="l.Id" class="jf-list-row jf-lists-row">
                    <NavLink href="@($"/lists/{l.Id}")" class="jf-lists-row-link">
                        <span style="display: flex; flex-direction: column;">
                            <span style="font-weight: 500;">@l.Title</span>
                            <span class="jf-muted" style="font-size: 0.8125rem;">Shared by @l.SharedByUserName</span>
                        </span>
                        <span class="jf-muted" style="font-size: 1.25rem;" aria-hidden="true">›</span>
                    </NavLink>
                    <button type="button"
                            class="jf-btn jf-btn-ghost"
                            title="Remove shared list from my account"
                            aria-label="Remove shared list from my account"
                            disabled="@_shareBusy"
                            @onclick="() => LeaveSharedListAsync(l.Id)">
                        Cancel
                    </button>
                </div>
            }
        }
    </div>
}

<div class="jf-card jf-stack-tight">
    <div class="jf-field">
        <label>New list</label>
        <InputText class="jf-input" @bind-Value="_newTitle" placeholder="e.g. Weekly groceries" disabled="@IsActionBusy" />
    </div>
    <button type="button" class="jf-btn jf-btn-primary" style="width: 100%;" disabled="@IsActionBusy" @onclick="CreateListAsync">Create</button>
</div>

@code {
    private List<ProductListSummaryDto>? _lists;
    private string _newTitle = string.Empty;
    private string? _error;

    private bool _toastVisible;
    private string _toastMessage = string.Empty;
    private ProductListDetailDto? _undoListSnapshot;
    private CancellationTokenSource? _toastCts;
    private CancellationTokenSource? _shareSearchCts;
    private Guid? _busyDeletingId;
    private bool _busyCreating;
    private bool _busyUndo;
    private bool _shareBusy;
    private bool _shareSearchBusy;
    private Guid? _shareListId;
    private string _shareQuery = string.Empty;
    private List<ShareUserSearchResultDto> _shareCandidates = [];
    private List<ProductListShareMemberDto> _shareMembers = [];
    private Guid? _selectedShareUserId;
    private bool IsActionBusy => _busyCreating || _busyDeletingId.HasValue || _busyUndo;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _error = null;
        var client = HttpClientFactory.CreateClient("Api");
        var response = await client.GetAsync("api/product-lists");
        if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (!response.IsSuccessStatusCode)
        {
            _error = "Could not load lists.";
            return;
        }

        _lists = await response.Content.ReadFromJsonAsync<List<ProductListSummaryDto>>();
    }

    private async Task OpenSharePanel(Guid listId)
    {
        _shareListId = listId;
        _shareQuery = string.Empty;
        _shareCandidates.Clear();
        _shareMembers.Clear();
        _selectedShareUserId = null;
        _shareSearchBusy = false;
        _shareSearchCts?.Cancel();

        var client = HttpClientFactory.CreateClient("Api");
        var response = await client.GetAsync($"api/product-lists/{listId}/shares");
        if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (!response.IsSuccessStatusCode)
            return;

        _shareMembers = await response.Content.ReadFromJsonAsync<List<ProductListShareMemberDto>>() ?? [];
    }

    private void CloseSharePanel()
    {
        _shareSearchCts?.Cancel();
        _shareListId = null;
        _shareQuery = string.Empty;
        _shareCandidates.Clear();
        _shareMembers.Clear();
        _selectedShareUserId = null;
        _shareSearchBusy = false;
    }

    private void SelectShareCandidate(Guid userId) => _selectedShareUserId = userId;

    private async Task OnShareQueryChanged(ChangeEventArgs args)
    {
        _shareQuery = args.Value?.ToString() ?? string.Empty;
        _selectedShareUserId = null;

        _shareSearchCts?.Cancel();
        _shareSearchCts?.Dispose();
        _shareSearchCts = new CancellationTokenSource();
        var token = _shareSearchCts.Token;
        var term = _shareQuery.Trim();

        if (term.Length < 3)
        {
            _shareCandidates.Clear();
            _shareSearchBusy = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        _shareSearchBusy = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(250, token);
            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.GetAsync($"api/product-lists/users/search?query={Uri.EscapeDataString(term)}", token);
            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _shareCandidates.Clear();
                return;
            }

            _shareCandidates = await response.Content.ReadFromJsonAsync<List<ShareUserSearchResultDto>>(token) ?? [];
        }
        catch (OperationCanceledException)
        {
            return;
        }
        finally
        {
            _shareSearchBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ShareSelectedAsync()
    {
        if (_shareListId is null || _selectedShareUserId is null)
            return;

        _shareBusy = true;
        _error = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.PostAsJsonAsync(
                $"api/product-lists/{_shareListId}/shares",
                new ShareProductListRequest { UserId = _selectedShareUserId.Value });

            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not share list.";
                return;
            }

            CloseSharePanel();
            await LoadAsync();
        }
        finally
        {
            _shareBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task UnshareAsync(Guid userId)
    {
        if (_shareListId is null)
            return;

        _shareBusy = true;
        _error = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.DeleteAsync($"api/product-lists/{_shareListId}/shares/{userId}");
            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not remove access.";
                return;
            }

            _shareMembers = _shareMembers.Where(m => m.UserId != userId).ToList();
        }
        finally
        {
            _shareBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LeaveSharedListAsync(Guid listId)
    {
        _shareBusy = true;
        _error = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.DeleteAsync($"api/product-lists/{listId}/shares/me");
            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not remove shared list.";
                return;
            }

            if (await LastOpenedList.GetAsync() == listId)
                await LastOpenedList.ClearAsync();

            await LoadAsync();
        }
        finally
        {
            _shareBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CreateListAsync()
    {
        if (string.IsNullOrWhiteSpace(_newTitle))
            return;

        _error = null;
        _busyCreating = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.PostAsJsonAsync(
                "api/product-lists",
                new CreateProductListRequest { Title = _newTitle.Trim() });
            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not create list.";
                return;
            }

            _newTitle = string.Empty;
            await LoadAsync();
        }
        finally
        {
            _busyCreating = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DeleteListAsync(Guid id)
    {
        if (_busyDeletingId.HasValue)
            return;

        _busyDeletingId = id;
        _error = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            var detailResponse = await client.GetAsync($"api/product-lists/{id}");
            if (detailResponse.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!detailResponse.IsSuccessStatusCode)
            {
                _error = "Could not load list.";
                return;
            }

            var snapshot = await detailResponse.Content.ReadFromJsonAsync<ProductListDetailDto>();
            if (snapshot is null)
                return;

            var deleteResponse = await client.DeleteAsync($"api/product-lists/{id}");
            if (deleteResponse.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!deleteResponse.IsSuccessStatusCode)
            {
                _error = "Could not delete list.";
                return;
            }

            if (await LastOpenedList.GetAsync() == id)
                await LastOpenedList.ClearAsync();

            _undoListSnapshot = snapshot;
            await ShowListDeletedToastAsync(snapshot.Title);
            await LoadAsync();
        }
        finally
        {
            _busyDeletingId = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ShowListDeletedToastAsync(string title)
    {
        _toastCts?.Cancel();
        _toastCts?.Dispose();
        _toastCts = new CancellationTokenSource();
        _toastMessage = $"\"{title}\" removed.";
        _toastVisible = true;
        await InvokeAsync(StateHasChanged);

        _ = DismissToastAfterDelayAsync(_toastCts.Token);
    }

    private async Task DismissToastAfterDelayAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(3000, token);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        await InvokeAsync(() =>
        {
            _toastVisible = false;
            _undoListSnapshot = null;
            StateHasChanged();
        });
    }

    private async Task UndoDeleteListAsync()
    {
        if (_undoListSnapshot is null)
            return;

        _busyUndo = true;
        _toastCts?.Cancel();
        var snap = _undoListSnapshot;
        _undoListSnapshot = null;
        _toastVisible = false;
        await InvokeAsync(StateHasChanged);

        try
        {
            _error = null;
            var client = HttpClientFactory.CreateClient("Api");
            var createResponse = await client.PostAsJsonAsync(
                "api/product-lists",
                new CreateProductListRequest { Title = snap.Title });

            if (createResponse.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!createResponse.IsSuccessStatusCode)
            {
                _error = "Could not restore list.";
                await InvokeAsync(StateHasChanged);
                return;
            }

            var created = await createResponse.Content.ReadFromJsonAsync<ProductListSummaryDto>();
            if (created is null)
            {
                _error = "Could not restore list.";
                await InvokeAsync(StateHasChanged);
                return;
            }

            var oldToNew = new Dictionary<Guid, Guid>();
            foreach (var item in snap.Items.OrderBy(i => i.SortOrder))
            {
                var itemResponse = await client.PostAsJsonAsync(
                    $"api/product-lists/{created.Id}/items",
                    new AddProductListItemRequest
                    {
                        Name = item.Name.Trim(),
                        Quantity = item.Quantity,
                    });

                if (itemResponse.StatusCode == HttpStatusCode.Unauthorized)
                {
                    Navigation.NavigateTo("/login");
                    return;
                }

                if (!itemResponse.IsSuccessStatusCode)
                {
                    _error = "Could not restore item.";
                    await InvokeAsync(StateHasChanged);
                    return;
                }

                var added = await itemResponse.Content.ReadFromJsonAsync<ProductListItemDto>();
                if (added is not null)
                    oldToNew[item.Id] = added.Id;
            }

            foreach (var item in snap.Items.Where(i => i.IsPurchased))
            {
                if (!oldToNew.TryGetValue(item.Id, out var newId))
                    continue;

                var patchResponse = await client.PatchAsJsonAsync(
                    $"api/product-lists/{created.Id}/items/{newId}",
                    new SetProductListItemPurchasedRequest { IsPurchased = true });

                if (patchResponse.StatusCode == HttpStatusCode.Unauthorized)
                {
                    Navigation.NavigateTo("/login");
                    return;
                }

                if (!patchResponse.IsSuccessStatusCode)
                {
                    _error = "Could not restore item.";
                    await InvokeAsync(StateHasChanged);
                    return;
                }
            }

            await LoadAsync();
        }
        finally
        {
            _busyUndo = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        _shareSearchCts?.Cancel();
        _shareSearchCts?.Dispose();
        _toastCts?.Cancel();
        _toastCts?.Dispose();
    }
}
