@page "/register"
@layout AuthLayout
@using System.Net
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Register — JuniperFox</PageTitle>

<h1 style="margin-bottom: 0.25rem;">Register</h1>
<p class="jf-muted" style="margin-bottom: 1.5rem;">Create an account for shared lists.</p>

@if (_busy)
{
    <div class="jf-busy-overlay" role="status" aria-live="polite" aria-label="Creating account">
        <div class="jf-spinner" aria-hidden="true"></div>
    </div>
}

@if (!string.IsNullOrEmpty(_error))
{
    <p class="jf-error">@_error</p>
}

<EditForm Model="_model" OnValidSubmit="HandleRegister">
    <div class="jf-stack-tight">
        <div class="jf-field">
            <label>Username</label>
            <InputText class="jf-input" @bind-Value="_model.UserName" autocomplete="username" disabled="@_busy" />
        </div>
        <div class="jf-field">
            <label>PIN (4 digits)</label>
            <InputText class="jf-input" @bind-Value="_model.Pin" type="password" autocomplete="new-password" inputmode="numeric" disabled="@_busy" />
        </div>
        <button type="submit" class="jf-btn jf-btn-primary" style="width: 100%; margin-top: 0.25rem;" disabled="@_busy">Create account</button>
    </div>
</EditForm>

<p class="jf-muted" style="margin-top: 1.5rem; text-align: center; font-size: 0.875rem;">
    Already have an account? <NavLink href="/login">Sign in</NavLink>
</p>

@code {
    private RegisterModel _model = new();
    private string? _error;
    private bool _busy;

    private async Task HandleRegister()
    {
        if (_busy)
            return;

        _busy = true;
        _error = null;
        var userName = _model.UserName.Trim();
        if (string.IsNullOrEmpty(userName))
        {
            _error = "Enter a username.";
            _busy = false;
            return;
        }

        var pin = _model.Pin;
        var client = HttpClientFactory.CreateClient("Api");
        await InvokeAsync(StateHasChanged);

        try
        {
            var response = await client.PostAsJsonAsync(
                "api/auth/register",
                new RegisterRequest { UserName = userName, Pin = pin });

            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                _error = string.IsNullOrWhiteSpace(body) ? "Registration failed." : body;
                return;
            }

            // Ensure auth cookie/session exists in the browser by performing an explicit login.
            // This keeps the user signed in immediately after registration.
            var loginResponse = await client.PostAsJsonAsync(
                "api/auth/login",
                new LoginRequest { UserName = userName, Pin = pin });

            if (!loginResponse.IsSuccessStatusCode)
            {
                _error = "Sign-in after registration failed.";
                return;
            }

            Navigation.NavigateTo("/");
        }
        finally
        {
            _busy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private sealed class RegisterModel
    {
        public string UserName { get; set; } = string.Empty;
        public string Pin { get; set; } = string.Empty;
    }
}
