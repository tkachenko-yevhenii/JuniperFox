@page "/lists/{Id:guid}"
@using System.Net
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using JuniperFox.Web.Services
@implements IAsyncDisposable
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject LastOpenedListStorage LastOpenedList
@inject IJSRuntime JS

<PageTitle>@(_detail?.Title ?? "List") — JuniperFox</PageTitle>

@if (_toastVisible)
{
    <div class="jf-toast-host" role="status" aria-live="polite">
        <div class="jf-toast">
            <span class="jf-toast-msg">@_toastMessage</span>
            <div class="jf-toast-actions">
                <button type="button" class="jf-btn jf-btn-ghost" disabled="@IsActionBusy" @onclick="UndoDeleteAsync">Undo</button>
            </div>
        </div>
    </div>
}

@if (_detail is null)
{
    @if (!string.IsNullOrEmpty(_error))
    {
        <p class="jf-error">@_error</p>
    }
    else
    {
        <div class="jf-list-detail-page jf-list-detail-page--pending" aria-busy="true"></div>
    }
}
else
{
    <div class="jf-list-detail-page">
        <div class="jf-list-detail-scroll">
            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="jf-error">@_error</p>
            }
            <div class="jf-list-detail-title-row">
                <h1>@_detail.Title</h1>
                @if (_canShare)
                {
                    <button type="button"
                            class="jf-list-share-icon"
                            title="Share list"
                            aria-label="Share list"
                            disabled="@(_shareBusy || IsActionBusy)"
                            @onclick="ToggleSharePanelAsync">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M7 12a3 3 0 100-6 3 3 0 000 6zm10 10a3 3 0 100-6 3 3 0 000 6zM17 8a3 3 0 100-6 3 3 0 000 6zM9.58 10.42l4.84-2.84M9.58 13.58l4.84 2.84" />
                        </svg>
                    </button>
                }
            </div>
            @if (_canShare && _sharePanelOpen)
            {
                <div class="jf-card jf-stack-tight" style="margin-bottom: 0.85rem;">
                    <div class="jf-field">
                        <label>Find account to share with</label>
                        <input class="jf-input"
                               value="@_shareQuery"
                               placeholder="At least 3 characters"
                               @oninput="OnShareQueryChanged"
                               disabled="@_shareBusy" />
                    </div>
                    @if (_shareQuery.Trim().Length > 0 && _shareQuery.Trim().Length < 3)
                    {
                        <p class="jf-muted" style="margin: 0;">Type at least 3 symbols.</p>
                    }
                    @if (_shareSearchBusy)
                    {
                        <p class="jf-muted" style="margin: 0;">Searching…</p>
                    }
                    else if (_shareQuery.Trim().Length >= 3)
                    {
                        @if (_shareCandidates.Count == 0)
                        {
                            <p class="jf-muted" style="margin: 0;">No users found.</p>
                        }
                        else
                        {
                            <div class="jf-stack-tight">
                                @foreach (var user in _shareCandidates)
                                {
                                    var selected = _selectedShareUserId == user.Id;
                                    <button type="button"
                                            class="jf-btn @(selected ? "jf-btn-primary" : "jf-btn-ghost")"
                                            style="justify-content: flex-start;"
                                            @onclick="() => SelectShareCandidate(user.Id)">
                                        @user.UserName
                                    </button>
                                }
                            </div>
                        }
                    }
                    @if (_shareMembers.Count > 0)
                    {
                        <div class="jf-stack-tight" style="margin-top: 0.5rem;">
                            <p class="jf-muted" style="margin: 0;">Already shared with</p>
                            @foreach (var member in _shareMembers)
                            {
                                <div class="jf-list-row" style="margin-bottom: 0;">
                                    <span>@member.UserName</span>
                                    <button type="button"
                                            class="jf-btn jf-btn-ghost"
                                            disabled="@_shareBusy"
                                            @onclick="() => UnshareAsync(member.UserId)">
                                        Unshare
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    <div style="display: flex; gap: 0.75rem;">
                        <button type="button"
                                class="jf-btn jf-btn-primary"
                                disabled="@(_selectedShareUserId is null || _shareBusy)"
                                @onclick="ShareSelectedAsync">
                            OK
                        </button>
                        <button type="button"
                                class="jf-btn jf-btn-ghost"
                                disabled="@_shareBusy"
                                @onclick="CloseSharePanel">
                            Cancel
                        </button>
                    </div>
                </div>
            }

            @if (_detail.Items.Count > 0)
            {
                var openItems = _detail.Items.Where(i => !i.IsPurchased).ToList();
                var doneItems = _detail.Items.Where(i => i.IsPurchased).ToList();
                var hasOpen = openItems.Count > 0;
                var hasDone = doneItems.Count > 0;
                <div class="jf-list-detail-items">
                    @foreach (var item in openItems)
                    {
                        <div @key="item.Id"
                             class="jf-list-row jf-item-row jf-item-row-animated @(item.IsPurchased ? "jf-item-purchased" : null) @(_busyItemId == item.Id ? "jf-item-row-busy" : null)"
                             style="@GetItemRowStyle(item.Id)"
                             role="button"
                             tabindex="0"
                             @onclick="() => OnRowClickAsync(item)"
                             @ontouchstart="e => OnItemTouchStart(item, e)"
                             @ontouchmove="e => OnItemTouchMove(item, e)"
                             @ontouchend="e => OnItemTouchEndAsync(item, e)"
                             @ontouchcancel="() => OnItemTouchCancel(item)"
                             @onkeydown="e => OnRowKeyDownAsync(item, e)">
                            <span class="jf-item-label">
                                @item.Name
                                @if (!string.IsNullOrWhiteSpace(item.Quantity))
                                {
                                    <span class="jf-muted"> · @item.Quantity</span>
                                }
                            </span>
                            <button type="button"
                                    class="jf-item-delete"
                                    title="Delete"
                                    aria-label="Delete item"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => DeleteItemAsync(item)">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                </svg>
                            </button>
                        </div>
                    }
                    @if (hasOpen && hasDone)
                    {
                        <div class="jf-item-group-gap" aria-hidden="true"></div>
                    }
                    @foreach (var item in doneItems)
                    {
                        <div @key="item.Id"
                             class="jf-list-row jf-item-row jf-item-row-animated jf-item-purchased @(_busyItemId == item.Id ? "jf-item-row-busy" : null)"
                             style="@GetItemRowStyle(item.Id)"
                             role="button"
                             tabindex="0"
                             @onclick="() => OnRowClickAsync(item)"
                             @ontouchstart="e => OnItemTouchStart(item, e)"
                             @ontouchmove="e => OnItemTouchMove(item, e)"
                             @ontouchend="e => OnItemTouchEndAsync(item, e)"
                             @ontouchcancel="() => OnItemTouchCancel(item)"
                             @onkeydown="e => OnRowKeyDownAsync(item, e)">
                            <span class="jf-item-label">
                                @item.Name
                                @if (!string.IsNullOrWhiteSpace(item.Quantity))
                                {
                                    <span class="jf-muted"> · @item.Quantity</span>
                                }
                            </span>
                            <button type="button"
                                    class="jf-item-delete"
                                    title="Delete"
                                    aria-label="Delete item"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => DeleteItemAsync(item)">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                </svg>
                            </button>
                        </div>
                    }
                </div>
            }
        </div>

        <button type="button"
                class="jf-fab-add-item"
                aria-label="Add item"
                @onclick="OpenAddModal">
            <span aria-hidden="true">+</span>
        </button>

        @if (_addModalOpen)
        {
            <div class="jf-modal-backdrop" role="dialog" aria-modal="true">
                <div class="jf-card jf-modal">
                    <h2>Add item</h2>
                    <div class="jf-stack-tight">
                        <div class="jf-field">
                            <label for="add-item-name">Name</label>
                            <input id="add-item-name"
                                   class="jf-input"
                                   value="@_itemName"
                                   placeholder="e.g. Milk"
                                   disabled="@_addBusy"
                                   @oninput="e => _itemName = e.Value?.ToString() ?? string.Empty" />
                        </div>
                        <div class="jf-field">
                            <label for="add-item-quantity">Amount / note (optional)</label>
                            <InputText id="add-item-quantity"
                                       class="jf-input"
                                       @bind-Value="_quantityText"
                                       placeholder="e.g. 15 liters, 8 pcs"
                                       disabled="@_addBusy" />
                        </div>
                        <div class="jf-modal-actions">
                            <button type="button"
                                    class="jf-btn jf-btn-primary"
                                    @onclick="AddItemAsync">
                                Add
                            </button>
                            <button type="button"
                                    class="jf-btn jf-btn-ghost"
                                    disabled="@_addBusy"
                                    @onclick="CloseAddModal">
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private ProductListDetailDto? _detail;
    private string _itemName = string.Empty;
    private string _quantityText = string.Empty;
    private string? _error;
    private Guid? _busyItemId;
    private HubConnection? _hubConnection;
    private Guid? _hubSubscribedListId;
    private IJSObjectReference? _crossTabModule;
    private DotNetObjectReference<ListDetail>? _crossTabDotNetRef;
    private int _crossTabSubscriptionId;
    private Guid _crossTabBoundListId;
    private readonly SemaphoreSlim _loadLock = new(1, 1);

    private bool _toastVisible;
    private string _toastMessage = string.Empty;
    private string? _undoName;
    private string? _undoQuantity;
    private CancellationTokenSource? _toastCts;

    private bool _addModalOpen;
    private bool _addBusy;
    private bool _undoBusy;
    private bool IsActionBusy => _addBusy || _undoBusy;
    private bool _canShare;
    private bool _sharePanelOpen;
    private bool _shareBusy;
    private bool _shareSearchBusy;
    private string _shareQuery = string.Empty;
    private List<ShareUserSearchResultDto> _shareCandidates = [];
    private List<ProductListShareMemberDto> _shareMembers = [];
    private Guid? _selectedShareUserId;
    private CancellationTokenSource? _shareSearchCts;
    private Guid? _touchItemId;
    private double _touchStartX;
    private double _touchStartY;
    private Guid? _suppressTapItemId;
    private DateTimeOffset _suppressTapUntilUtc;
    private const double SwipeThresholdPx = 70;
    private const double SwipeVerticalTolerancePx = 36;
    private const double SwipeMaxOffsetPx = 120;
    private readonly Dictionary<Guid, double> _swipeOffsetByItemId = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        await ConnectRealtimeAsync();
    }

    private void OpenAddModal() => _addModalOpen = true;

    private void CloseAddModal()
    {
        _addModalOpen = false;
        _itemName = string.Empty;
        _quantityText = string.Empty;
    }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();

        if (_hubConnection is null || _hubSubscribedListId == Id)
            return;

        try
        {
            if (_hubSubscribedListId is { } oldId &&
                _hubConnection.State == HubConnectionState.Connected)
            {
                await _hubConnection.InvokeAsync("UnsubscribeFromList", oldId);
            }

            if (_hubConnection.State == HubConnectionState.Connected)
            {
                await _hubConnection.InvokeAsync("SubscribeToList", Id);
                _hubSubscribedListId = Id;
            }
        }
        catch
        {
            // Keep page usable; cross-tab sync may still refresh.
        }

        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_crossTabBoundListId == Id && _crossTabSubscriptionId != 0)
            return;

        try
        {
            _crossTabModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/listCrossTab.js");
            _crossTabDotNetRef ??= DotNetObjectReference.Create(this);

            if (_crossTabSubscriptionId != 0)
            {
                await _crossTabModule.InvokeVoidAsync("unsubscribeFromList", _crossTabSubscriptionId);
                _crossTabSubscriptionId = 0;
            }

            _crossTabSubscriptionId = await _crossTabModule.InvokeAsync<int>(
                "subscribeToList",
                _crossTabDotNetRef,
                Id.ToString());
            _crossTabBoundListId = Id;
        }
        catch
        {
            // Optional; SignalR remains primary when connected.
        }
    }

    private async Task LoadAsync()
    {
        await _loadLock.WaitAsync();
        try
        {
            _error = null;

            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.GetAsync($"api/product-lists/{Id}");
            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (response.StatusCode == HttpStatusCode.NotFound)
            {
                await LastOpenedList.ClearAsync();
                Navigation.NavigateTo("/lists", replace: true);
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not load list.";
                return;
            }

            _detail = await response.Content.ReadFromJsonAsync<ProductListDetailDto>();
            if (_detail is not null)
            {
                await LastOpenedList.SetAsync(Id);
                await LoadShareMembersOrDisableAsync();
            }
        }
        finally
        {
            _loadLock.Release();
        }
    }

    private async Task ConnectRealtimeAsync()
    {
        var client = HttpClientFactory.CreateClient("Api");
        var hubUri = new Uri(client.BaseAddress!, "hubs/lists");

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUri, options =>
            {
                options.HttpMessageHandlerFactory = inner => new IncludeRequestCredentialsHandler
                {
                    InnerHandler = inner,
                };
            })
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<Guid>("ListChanged", async listId =>
        {
            if (listId != Id)
                return;

            await InvokeAsync(async () =>
            {
                await LoadAsync();
                StateHasChanged();
            });
        });

        try
        {
            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("SubscribeToList", Id);
            _hubSubscribedListId = Id;
        }
        catch
        {
            // Real-time is optional: keep list usable with manual/REST refresh.
        }
    }

    [JSInvokable]
    public async Task OnListSyncFromOtherTab()
    {
        await InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });
    }

    private async Task PublishCrossTabListChangedAsync()
    {
        if (_crossTabModule is null)
            return;

        try
        {
            await _crossTabModule.InvokeVoidAsync("publishListChanged", Id.ToString());
        }
        catch
        {
            // Ignore
        }
    }

    private async Task OnRowKeyDownAsync(ProductListItemDto item, KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == " ")
            await TogglePurchasedAsync(item);
    }

    private async Task OnRowClickAsync(ProductListItemDto item)
    {
        if (ShouldSuppressTap(item.Id))
            return;

        await TogglePurchasedAsync(item);
    }

    private void OnItemTouchStart(ProductListItemDto item, TouchEventArgs e)
    {
        if (e.Touches is null || e.Touches.Length == 0)
            return;

        var touch = e.Touches[0];
        _touchItemId = item.Id;
        _touchStartX = touch.ClientX;
        _touchStartY = touch.ClientY;
        _swipeOffsetByItemId[item.Id] = 0;
    }

    private void OnItemTouchMove(ProductListItemDto item, TouchEventArgs e)
    {
        if (_touchItemId != item.Id || e.Touches is null || e.Touches.Length == 0)
            return;

        var touch = e.Touches[0];
        var deltaX = touch.ClientX - _touchStartX;
        var deltaY = touch.ClientY - _touchStartY;

        if (Math.Abs(deltaY) > SwipeVerticalTolerancePx)
            return;

        var clamped = Math.Max(-SwipeMaxOffsetPx, Math.Min(SwipeMaxOffsetPx, deltaX));
        _swipeOffsetByItemId[item.Id] = clamped;
    }

    private async Task OnItemTouchEndAsync(ProductListItemDto item, TouchEventArgs e)
    {
        if (_touchItemId != item.Id)
            return;

        _touchItemId = null;
        if (e.ChangedTouches is null || e.ChangedTouches.Length == 0)
            return;

        var touch = e.ChangedTouches[0];
        var deltaX = touch.ClientX - _touchStartX;
        var deltaY = touch.ClientY - _touchStartY;
        var absX = Math.Abs(deltaX);
        var absY = Math.Abs(deltaY);
        _swipeOffsetByItemId[item.Id] = 0;

        if (absX < SwipeThresholdPx || absY > SwipeVerticalTolerancePx)
            return;

        SuppressTap(item.Id);
        if (deltaX < 0)
        {
            await TogglePurchasedAsync(item);
            return;
        }

        await DeleteItemAsync(item);
    }

    private void OnItemTouchCancel(ProductListItemDto item)
    {
        if (_touchItemId == item.Id)
            _touchItemId = null;

        _swipeOffsetByItemId[item.Id] = 0;
    }

    private string GetItemRowStyle(Guid itemId)
    {
        if (!_swipeOffsetByItemId.TryGetValue(itemId, out var offset) || Math.Abs(offset) < 0.5)
            return "touch-action: pan-y;";

        return $"touch-action: pan-y; transform: translateX({offset:0.#}px); transition: transform 0.06s linear;";
    }

    private async Task ToggleSharePanelAsync()
    {
        _sharePanelOpen = !_sharePanelOpen;
        if (_sharePanelOpen)
            await LoadShareMembersOrDisableAsync();
    }

    private void CloseSharePanel()
    {
        _sharePanelOpen = false;
        _shareQuery = string.Empty;
        _shareCandidates.Clear();
        _selectedShareUserId = null;
        _shareSearchBusy = false;
        _shareSearchCts?.Cancel();
    }

    private async Task LoadShareMembersOrDisableAsync()
    {
        var client = HttpClientFactory.CreateClient("Api");
        var response = await client.GetAsync($"api/product-lists/{Id}/shares");
        if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (!response.IsSuccessStatusCode)
        {
            _canShare = false;
            _sharePanelOpen = false;
            _shareMembers.Clear();
            return;
        }

        _canShare = true;
        _shareMembers = await response.Content.ReadFromJsonAsync<List<ProductListShareMemberDto>>() ?? [];
    }

    private void SelectShareCandidate(Guid userId) => _selectedShareUserId = userId;

    private async Task OnShareQueryChanged(ChangeEventArgs args)
    {
        _shareQuery = args.Value?.ToString() ?? string.Empty;
        _selectedShareUserId = null;

        _shareSearchCts?.Cancel();
        _shareSearchCts?.Dispose();
        _shareSearchCts = new CancellationTokenSource();
        var token = _shareSearchCts.Token;
        var term = _shareQuery.Trim();

        if (term.Length < 3)
        {
            _shareCandidates.Clear();
            _shareSearchBusy = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        _shareSearchBusy = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(250, token);
            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.GetAsync($"api/product-lists/users/search?query={Uri.EscapeDataString(term)}", token);
            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _shareCandidates.Clear();
                return;
            }

            _shareCandidates = await response.Content.ReadFromJsonAsync<List<ShareUserSearchResultDto>>(token) ?? [];
            if (_shareCandidates.Count == 1)
            {
                _selectedShareUserId = _shareCandidates[0].Id;
            }
            else if (_selectedShareUserId is { } selectedId && _shareCandidates.All(c => c.Id != selectedId))
            {
                _selectedShareUserId = null;
            }
        }
        catch (OperationCanceledException)
        {
            return;
        }
        finally
        {
            _shareSearchBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ShareSelectedAsync()
    {
        var selectedUserId = _selectedShareUserId ?? _shareCandidates.FirstOrDefault()?.Id;
        if (selectedUserId is null)
        {
            _error = "Select account to share.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        _shareBusy = true;
        _error = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.PostAsJsonAsync(
                $"api/product-lists/{Id}/shares",
                new ShareProductListRequest { UserId = selectedUserId.Value });

            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                var apiText = await response.Content.ReadAsStringAsync();
                _error = string.IsNullOrWhiteSpace(apiText) ? "Could not share list." : apiText;
                return;
            }

            _shareQuery = string.Empty;
            _shareCandidates.Clear();
            _selectedShareUserId = null;
            await LoadShareMembersOrDisableAsync();
        }
        finally
        {
            _shareBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task UnshareAsync(Guid userId)
    {
        _shareBusy = true;
        _error = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.DeleteAsync($"api/product-lists/{Id}/shares/{userId}");
            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not remove access.";
                return;
            }

            _shareMembers = _shareMembers.Where(m => m.UserId != userId).ToList();
        }
        finally
        {
            _shareBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void SuppressTap(Guid itemId)
    {
        _suppressTapItemId = itemId;
        _suppressTapUntilUtc = DateTimeOffset.UtcNow.AddMilliseconds(450);
    }

    private bool ShouldSuppressTap(Guid itemId)
    {
        if (_suppressTapItemId != itemId)
            return false;

        if (DateTimeOffset.UtcNow > _suppressTapUntilUtc)
            return false;

        _suppressTapItemId = null;
        return true;
    }

    private async Task TogglePurchasedAsync(ProductListItemDto item)
    {
        // Оптимистичное обновление UI: сразу переключаем и пересортировываем локальный список.
        ApplyOptimisticToggle(item.Id);
        await InvokeAsync(StateHasChanged);

        // Запрос к серверу — отдельно, не блокирует интерфейс.
        _ = SetPurchasedOnServerAsync(item.Id, !item.IsPurchased);
    }

    private void ApplyOptimisticToggle(Guid itemId)
    {
        if (_detail is null)
            return;

        var items = _detail.Items.ToList();
        var index = items.FindIndex(i => i.Id == itemId);
        if (index < 0)
            return;

        var current = items[index];
        items[index] = new ProductListItemDto
        {
            Id = current.Id,
            Name = current.Name,
            SortOrder = current.SortOrder,
            Quantity = current.Quantity,
            IsPurchased = !current.IsPurchased,
        };

        var open = items.Where(i => !i.IsPurchased).OrderBy(i => i.SortOrder).ToList();
        var done = items.Where(i => i.IsPurchased).OrderBy(i => i.SortOrder).ToList();

        _detail = new ProductListDetailDto
        {
            Id = _detail.Id,
            Title = _detail.Title,
            CreatedAtUtc = _detail.CreatedAtUtc,
            Items = [.. open, .. done],
        };
    }

    private async Task SetPurchasedOnServerAsync(Guid itemId, bool isPurchased)
    {
        _busyItemId = itemId;
        _error = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.PatchAsJsonAsync(
                $"api/product-lists/{Id}/items/{itemId}",
                new SetProductListItemPurchasedRequest { IsPurchased = isPurchased });

            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not update item.";
                // В случае ошибки перезагружаем список, чтобы вернуть корректное состояние.
                await LoadAsync();
                return;
            }

            await PublishCrossTabListChangedAsync();
        }
        finally
        {
            _busyItemId = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DeleteItemAsync(ProductListItemDto item)
    {
        // Оптимистично убираем элемент из локального списка и сразу показываем toast.
        ApplyOptimisticDelete(item.Id);
        await ShowDeletedToastAsync(item.Name, item.Quantity);
        await InvokeAsync(StateHasChanged);

        // Удаление на сервере — в фоне.
        _ = DeleteItemOnServerAsync(item.Id);
    }

    private void ApplyOptimisticDelete(Guid itemId)
    {
        if (_detail is null)
            return;

        var items = _detail.Items.Where(i => i.Id != itemId).ToList();

        _detail = new ProductListDetailDto
        {
            Id = _detail.Id,
            Title = _detail.Title,
            CreatedAtUtc = _detail.CreatedAtUtc,
            Items = items,
        };
    }

    private async Task DeleteItemOnServerAsync(Guid itemId)
    {
        _busyItemId = itemId;
        _error = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.DeleteAsync($"api/product-lists/{Id}/items/{itemId}");

            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not delete item.";
                // В случае ошибки перезагружаем список и сбрасываем данные для Undo.
                _toastVisible = false;
                _undoName = null;
                _undoQuantity = null;
                await LoadAsync();
                return;
            }

            await PublishCrossTabListChangedAsync();
        }
        finally
        {
            _busyItemId = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ShowDeletedToastAsync(string name, string? quantity)
    {
        _toastCts?.Cancel();
        _toastCts?.Dispose();
        _toastCts = new CancellationTokenSource();
        _undoName = name;
        _undoQuantity = quantity;
        _toastMessage = $"\"{name}\" removed.";
        _toastVisible = true;
        await InvokeAsync(StateHasChanged);

        _ = DismissToastAfterDelayAsync(_toastCts.Token);
    }

    private async Task DismissToastAfterDelayAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(3000, token);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        await InvokeAsync(() =>
        {
            _toastVisible = false;
            _undoName = null;
            _undoQuantity = null;
            StateHasChanged();
        });
    }

    private async Task UndoDeleteAsync()
    {
        if (_undoName is null)
            return;

        _undoBusy = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            _toastCts?.Cancel();
            var name = _undoName;
            var qty = _undoQuantity;
            _toastVisible = false;
            _undoName = null;
            _undoQuantity = null;
            await InvokeAsync(StateHasChanged);

            _error = null;
            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.PostAsJsonAsync(
                $"api/product-lists/{Id}/items",
                new AddProductListItemRequest { Name = name, Quantity = qty });

            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not restore item.";
                await InvokeAsync(StateHasChanged);
                return;
            }

            await LoadAsync();
            await PublishCrossTabListChangedAsync();
        }
        finally
        {
            _undoBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task AddItemAsync()
    {
        if (_detail is null || string.IsNullOrWhiteSpace(_itemName))
            return;

        _error = null;
        var name = _itemName.Trim();
        var quantity = string.IsNullOrWhiteSpace(_quantityText) ? null : _quantityText.Trim();

        // Оптимистично добавляем элемент в локальный список и закрываем модалку.
        ApplyOptimisticAdd(name, quantity);
        _itemName = string.Empty;
        _quantityText = string.Empty;
        _addModalOpen = false;
        await InvokeAsync(StateHasChanged);

        // Добавление на сервере — в фоне.
        _ = AddItemOnServerAsync(name, quantity);
    }

    private void ApplyOptimisticAdd(string name, string? quantity)
    {
        if (_detail is null)
            return;

        var items = _detail.Items.ToList();
        var nextSortOrder = items.Count == 0 ? 0 : items.Max(i => i.SortOrder) + 1;

        var added = new ProductListItemDto
        {
            Id = Guid.NewGuid(),
            Name = name,
            SortOrder = nextSortOrder,
            Quantity = quantity,
            IsPurchased = false,
        };

        _detail = new ProductListDetailDto
        {
            Id = _detail.Id,
            Title = _detail.Title,
            CreatedAtUtc = _detail.CreatedAtUtc,
            Items = [.. items, added],
        };
    }

    private async Task AddItemOnServerAsync(string name, string? quantity)
    {
        _addBusy = true;
        await InvokeAsync(StateHasChanged);
        var client = HttpClientFactory.CreateClient("Api");
        try
        {
            var response = await client.PostAsJsonAsync(
                $"api/product-lists/{Id}/items",
                new AddProductListItemRequest
                {
                    Name = name,
                    Quantity = quantity,
                });

            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not add item.";
                await LoadAsync();
                return;
            }

            await LoadAsync();
            await PublishCrossTabListChangedAsync();
        }
        finally
        {
            _addBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _shareSearchCts?.Cancel();
        _shareSearchCts?.Dispose();
        _shareSearchCts = null;

        _toastCts?.Cancel();
        _toastCts?.Dispose();
        _toastCts = null;

        if (_crossTabModule is not null && _crossTabSubscriptionId != 0)
        {
            try
            {
                await _crossTabModule.InvokeVoidAsync("unsubscribeFromList", _crossTabSubscriptionId);
            }
            catch
            {
                // Ignore disposal errors.
            }

            _crossTabSubscriptionId = 0;
        }

        _crossTabDotNetRef?.Dispose();
        _crossTabDotNetRef = null;

        if (_crossTabModule is not null)
        {
            try
            {
                await _crossTabModule.DisposeAsync();
            }
            catch
            {
                // Ignore disposal errors.
            }

            _crossTabModule = null;
        }

        if (_hubConnection is not null)
        {
            try
            {
                if (_hubConnection.State == HubConnectionState.Connected)
                    await _hubConnection.InvokeAsync("UnsubscribeFromList", Id);
            }
            catch
            {
                // Ignore disconnect errors during page disposal/navigation.
            }

            await _hubConnection.DisposeAsync();
        }

        _loadLock.Dispose();
    }
}
